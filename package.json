{
  "name": "orc",
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @orc/api dev & bun run --filter @orc/cli dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome lint ./packages",
    "format": "biome format --write ./packages",
    "check": "biome check --write ./packages",
    "db:generate": "bun run --filter @orc/db generate",
    "db:push": "bun run --filter @orc/db push",
    "db:studio": "bun run --filter @orc/db studio",
    "sdk:generate": "bun run --filter @orc/sdk generate",
    "tui": "bun --hot packages/tui/src/index.tsx",
    "test": "bun run --filter '*' test",
    "clean": "bun run --filter '*' clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
