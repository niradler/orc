{
  "name": "orc",
  "version": "0.1.25",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @orc/api dev & bun run --filter @orc/cli dev & bun run --filter @orc/web dev",
    "dev-daemon": "bun run --filter orc-ai dev-daemon:start & bun run --filter @orc/web dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome lint ./packages",
    "format": "biome format --write ./packages",
    "check": "biome check --write ./packages",
    "db:generate": "bun run --filter @orc/db generate",
    "db:push": "bun run --filter @orc/db push",
    "db:studio": "bun run --filter @orc/db studio",
    "sdk:generate": "bun run --filter @orc/sdk generate",
    "test": "bun run --filter '*' test",
    "clean": "bun run --filter '*' clean"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "bun-types": "^1.3.12",
    "typescript": "^6.0.2"
  }
}
