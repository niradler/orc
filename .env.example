# Copy to .env and adjust. All values are optional — ORC runs with sane defaults.

# --- API ---
ORC_API_PORT=7701
# Bind address. Defaults to 127.0.0.1 (localhost-only). Use 0.0.0.0 to expose on the network.
# ORC_API_HOST=127.0.0.1
# Bearer token required for all endpoints except /health. REQUIRED when binding to a non-loopback host.
# Generate with: openssl rand -hex 32
# ORC_API_SECRET=

# --- Web dashboard (dev server) ---
ORC_WEB_PORT=3077

# --- Agent backends (only set what you use) ---
# ANTHROPIC_API_KEY=
# AGENTAPI_URL=http://host.docker.internal:3284
# ORC_AGENT_LOOP_DEFAULT_BACKEND=claude

# --- Gateway (optional) ---
# ORC_TELEGRAM_TOKEN=
# ORC_SLACK_BOT_TOKEN=
# ORC_SLACK_APP_TOKEN=

# --- Logging ---
# ORC_LOG_LEVEL=info
# ORC_LOG_DIR=
# ORC_LOG_FILE=1
