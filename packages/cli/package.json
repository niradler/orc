{
  "name": "@orc/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "orc": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --compile --outfile dist/orc --target bun",
    "build:all": "bun run build.ts",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@orc/core": "workspace:*",
    "@orc/sdk": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
