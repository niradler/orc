{
  "name": "orc-ai",
  "version": "0.1.14",
  "description": "Human + AI Orchestration Hub — persistent memory, task management, session continuity and multi-agent collaboration for Cursor, Claude Code, and Codex",
  "type": "module",
  "bin": {
    "orc": "dist/index.js"
  },
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun --minify --external @opentui/core-darwin-x64 --external @opentui/core-darwin-arm64 --external @opentui/core-linux-x64 --external @opentui/core-linux-arm64 --external @opentui/core-win32-x64 --external @opentui/core-win32-arm64",
    "build:bin": "bun run build.ts",
    "prepublishOnly": "cp ../../README.md . && bun run build",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "devDependencies": {
    "@orc/api": "workspace:*",
    "@orc/core": "workspace:*",
    "@orc/gateway": "workspace:*",
    "@orc/mcp": "workspace:*",
    "@orc/runner": "workspace:*",
    "@orc/sdk": "workspace:*",
    "@orc/tui": "workspace:*",
    "commander": "^14.0.3",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "@opentui/core-darwin-x64": "0.1.96",
    "@opentui/core-darwin-arm64": "0.1.96",
    "@opentui/core-linux-x64": "0.1.96",
    "@opentui/core-linux-arm64": "0.1.96",
    "@opentui/core-win32-x64": "0.1.96",
    "@opentui/core-win32-arm64": "0.1.96"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": false
    }
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "mcp",
    "claude",
    "cursor",
    "codex",
    "memory",
    "tasks",
    "hitl",
    "sessions"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niradler/orc.git"
  },
  "homepage": "https://github.com/niradler/orc",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
