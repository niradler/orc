{
  "name": "orc-ai",
  "version": "0.1.24",
  "description": "Human + AI Orchestration Hub - persistent memory, task management, session continuity and multi-agent collaboration for Cursor, Claude Code, and Codex",
  "type": "module",
  "bin": {
    "orc": "dist/index.js"
  },
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "dev-daemon:start": "bun --env-file ../../.env --watch src/index.ts daemon start",
    "daemon:stop": "bun --env-file ../../.env src/index.ts daemon stop",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:web": "cd ../web && bun run build",
    "build:copy-web": "bun run copy-web.ts",
    "build": "bun run build:web && bun build src/index.ts --outdir dist --target bun --minify --external '@tobilu/qmd' --external 'node-llama-cpp' --external '@node-llama-cpp/*' --external '@anthropic-ai/claude-agent-sdk' && bun run build:copy-web",
    "build:bin": "bun run build.ts",
    "validate:package": "bun run scripts/validate-package.ts",
    "prepublishOnly": "cp ../../README.md . && bun run build && bun run validate:package",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/index.js",
    "dist/checksums.txt",
    "dist/web",
    "README.md"
  ],
  "devDependencies": {
    "@orc/api": "workspace:*",
    "@orc/core": "workspace:*",
    "@orc/gateway": "workspace:*",
    "@orc/mcp": "workspace:*",
    "@orc/runner": "workspace:*",
    "@orc/sdk": "workspace:*",
    "@orc/web": "workspace:*",
    "commander": "^14.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.110",
    "@tobilu/qmd": "^2.1.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": false
    }
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "mcp",
    "claude",
    "cursor",
    "codex",
    "memory",
    "tasks",
    "hitl",
    "sessions"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niradler/orc.git"
  },
  "homepage": "https://github.com/niradler/orc",
  "bugs": {
    "url": "https://github.com/niradler/orc/issues"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
