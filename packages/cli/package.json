{
  "name": "orc-ai",
  "version": "0.1.19",
  "description": "Human + AI Orchestration Hub - persistent memory, task management, session continuity and multi-agent collaboration for Cursor, Claude Code, and Codex",
  "type": "module",
  "bin": {
    "orc": "dist/index.js"
  },
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:web": "cd ../web && bun run build",
    "build:copy-web": "bun run copy-web.ts",
    "build": "bun run build:web && bun build src/index.ts --outdir dist --target bun --minify --external '@tobilu/qmd' --external 'node-llama-cpp' --external '@node-llama-cpp/*' && bun run build:copy-web",
    "build:bin": "bun run build.ts",
    "prepublishOnly": "cp ../../README.md . && bun run build",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "devDependencies": {
    "@orc/api": "workspace:*",
    "@orc/core": "workspace:*",
    "@orc/gateway": "workspace:*",
    "@orc/mcp": "workspace:*",
    "@orc/runner": "workspace:*",
    "@orc/sdk": "workspace:*",
    "@orc/web": "workspace:*",
    "commander": "^14.0.3"
  },
  "dependencies": {
    "@tobilu/qmd": "^2.1.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": false
    }
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "mcp",
    "claude",
    "cursor",
    "codex",
    "memory",
    "tasks",
    "hitl",
    "sessions"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niradler/orc.git"
  },
  "homepage": "https://github.com/niradler/orc",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
