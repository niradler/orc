{
  "name": "@orc/web",
  "version": "0.1.21",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file ../../.env vite",
    "build": "bun --env-file ../../.env run tsc -b && bun --env-file ../../.env vite build",
    "preview": "bun --env-file ../../.env vite preview",
    "typecheck": "tsc --noEmit",
    "test": "bun run scripts/run-e2e.ts",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "test:e2e:ui": "bun run scripts/run-e2e.ts --ui",
    "test:e2e:real-agent": "bun run scripts/run-real-agent-demo.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@orc/sdk": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.0"
  }
}
