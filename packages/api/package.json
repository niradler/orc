{
  "name": "@orc/api",
  "version": "0.1.6",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.5.1",
    "@hono/zod-openapi": "^0.19.6",
    "@orc/core": "workspace:*",
    "@orc/db": "workspace:*",
    "@orc/gateway": "workspace:*",
    "@orc/mcp": "workspace:*",
    "@orc/runner": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
