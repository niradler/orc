{
  "name": "@orc/api",
  "version": "0.1.20",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun --env-file ../../.env --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun --external 'node-llama-cpp' --external '@node-llama-cpp/*'",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@orc/core": "workspace:*",
    "@orc/db": "workspace:*",
    "@orc/gateway": "workspace:*",
    "@orc/mcp": "workspace:*",
    "@orc/runner": "workspace:*",
    "@orc/task-service": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  }
}
