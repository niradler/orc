{
  "name": "@orc/mcp",
  "version": "0.1.25",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools.ts",
    "./knowledge": "./src/knowledge.ts"
  },
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun --external 'node-llama-cpp' --external '@node-llama-cpp/*'",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "optionalDependencies": {
    "@tobilu/qmd": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orc/core": "workspace:*",
    "@orc/db": "workspace:*",
    "@orc/runner": "workspace:*",
    "@orc/task-service": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@orc/api": "workspace:*"
  }
}
