    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@orc/core": "workspace:*",
    "@orc/db": "workspace:*",
    "@orc/runner": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@orc/api": "workspace:*",
    "typescript": "^5.7.3"
  }
}
